# Copie este arquivo para .env e preencha com suas chaves reais
# cp .env.example .env

# Chave da API Groq (https://console.groq.com)
GROQ_API_KEY=sua_chave_groq_aqui

# Chave da API Serper (https://serper.dev)
SERPER_API_KEY=sua_chave_serper_aqui

# Modelo LLM na Groq (substituto do Llama 3.1 70B)
GROQ_MODEL=llama-3.3-70b-versatile

# Ajustes para plano gratuito Groq (opcional)
# GROQ_MAX_TOKENS=2048
# GROQ_PAUSE_ENTRE_AGENTES=2
# GROQ_RATE_LIMIT_RETRIES=4
# GROQ_RATE_LIMIT_ESPERA_BASE=8

# Pastas (opcional — os valores padrão funcionam na maioria dos casos)
# KNOWLEDGE_BASE_DIR=./knowledge_base
# CHROMA_PERSIST_DIR=./data/chroma

# Modelo de embeddings local (opcional)
# EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
